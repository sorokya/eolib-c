# Doxygen configuration for eolib-c

PROJECT_NAME           = "eolib"
PROJECT_NUMBER         = 0.3.0
PROJECT_BRIEF          = "A core C library for writing applications related to Endless Online"
OUTPUT_DIRECTORY       = docs
CREATE_SUBDIRS         = NO

INPUT                  = include src docs
FILE_PATTERNS          = *.h *.c *.dox
RECURSIVE              = YES
EXCLUDE                =

OPTIMIZE_OUTPUT_FOR_C  = YES
EXTRACT_ALL            = YES
EXTRACT_STATIC         = YES
EXTRACT_PRIVATE        = YES

ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = YES
EXPAND_ONLY_PREDEF     = NO

GENERATE_HTML          = YES
HTML_OUTPUT            = html
GENERATE_LATEX         = NO

QUIET                  = YES
WARN_IF_UNDOCUMENTED   = NO
WARN_NO_PARAMDOC       = YES

SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO

MARKDOWN_SUPPORT       = YES
AUTOLINK_SUPPORT       = YES

STRIP_FROM_PATH        =

SHOW_ENUM_VALUES       = YES

TAB_SIZE               = 4
